# .env.example
# Copia este archivo a .env y rellena tus valores

# ════════════════════════════════════════════════════════════════════
#  SP-API (Selling Partner API) - Amazon
# ════════════════════════════════════════════════════════════════════
SP_API_REFRESH_TOKEN=Atzr|...
SP_API_CLIENT_ID=amzn1.application-oa2-client...
SP_API_CLIENT_SECRET=...
SP_API_MARKETPLACE_ID=A1RKKUPIHCS9HS  # Amazon.es (no cambiar)
SP_API_REGION=eu-west-1               # Europa (no cambiar)
SP_API_ENDPOINT=https://sellingpartnerapi-eu.amazon.com  # (no cambiar)
SP_API_SELLER_ID=YOUR_SELLER_ID

# ════════════════════════════════════════════════════════════════════
#  AWS (para autorización de SP-API)
# ════════════════════════════════════════════════════════════════════
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_ROLE_ARN=arn:aws:iam::123456789:role/FBA-Bot-Role

# ════════════════════════════════════════════════════════════════════
#  Keepa API (histórico de precios Amazon)
# ════════════════════════════════════════════════════════════════════
KEEPA_API_KEY=...

# ════════════════════════════════════════════════════════════════════
#  Telegram (Notificaciones)
# ════════════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=123456789:ABCdeFGhIjKlmNoPqRsTuVwXyZ...
TELEGRAM_CHAT_ID=987654321  # Tu user ID o chat ID del grupo

# ════════════════════════════════════════════════════════════════════
#  Base de Datos (PostgreSQL)
# ════════════════════════════════════════════════════════════════════
# Si usas docker-compose, dejar como está
DATABASE_URL=postgresql+asyncpg://fba:secret@postgres:5432/fba_bot

# ════════════════════════════════════════════════════════════════════
#  Redis (Cache y Queue)
# ════════════════════════════════════════════════════════════════════
# Si usas docker-compose, dejar como está
REDIS_URL=redis://redis:6379/0

# ════════════════════════════════════════════════════════════════════
#  Pipeline - Configuración de Rentabilidad
# ════════════════════════════════════════════════════════════════════
MIN_ROI_PCT=20.0                 # ROI mínimo requerido (%)
BSR_TOP_PCT=2.0                  # Top BSR requerido (%)
PREP_SHIPPING_FIXED=0.50         # Costo fijo de preparación + envío (€)
PIPELINE_CONCURRENCY=10          # Número de workers concurrentes

# ════════════════════════════════════════════════════════════════════
#  Doble Flujo (Dual Flow Scheduler) - NUEVO
# ════════════════════════════════════════════════════════════════════
# Horarios del Flujo 1 (Monitor de Tiendas) en formato HH:MM
# Ejemplo: "08:00 20:00" = 8 AM y 8 PM
DUAL_FLOW_MONITOR_TIMES=08:00 20:00

# Cooldown entre Flujo 1 y Flujo 2 (en segundos, default 300)
DUAL_FLOW_RATE_LIMIT_COOLDOWN=300

# Timeout máximo para Flujo 1 en minutos (default 60)
DUAL_FLOW_MAX_MONITOR_RUNTIME=60

# ════════════════════════════════════════════════════════════════════
#  Integración Base44
# ════════════════════════════════════════════════════════════════════
BASE44_WEBHOOK_URL=https://gorgeous-prime-profit-flow.base44.app/functions/webhookAlert
BOT_WEBHOOK_TOKEN=YourSecretTokenHere

# ════════════════════════════════════════════════════════════════════
#  Logging
# ════════════════════════════════════════════════════════════════════
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
